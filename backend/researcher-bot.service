[Unit]
Description=Solana Memecoin Autonomous Trading Bot - Researcher (Phase 2)
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/.openclaw/workspace/projects/crypto-trading-system
ExecStart=/home/ubuntu/.openclaw/workspace/projects/crypto-trading-system/venv/bin/python3 src/main.py
Restart=always
RestartSec=10
MemoryMax=512M
CPUQuota=50%
StandardOutput=journal
StandardError=journal
SyslogIdentifier=researcher-bot
EnvironmentFile=/home/ubuntu/.openclaw/workspace/projects/crypto-trading-system/secrets.env
EnvironmentFile=/home/ubuntu/.openclaw/workspace/projects/crypto-trading-system/.env

[Install]
WantedBy=multi-user.target

# PixelFirm Bot — Environment Variables
# Copy this to .env and fill in your values

# Telegram
BOT_TOKEN=your_telegram_bot_token_here
YOUR_CHAT_ID=your_telegram_chat_id_here       # Get via @userinfobot
ALLOWED_USER_IDS=123456789                    # Comma-separated for multiple users

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# MongoDB
MONGO_URI=mongodb://localhost:27017

# Redis
REDIS_URL=redis://localhost:6379

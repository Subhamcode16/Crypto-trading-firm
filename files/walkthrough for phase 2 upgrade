            return result
            
        except Exception as e:
            logger.error(f"[AGENT_5] Aggregation error: {e}")
            return None
    
    def _calculate_confidence(self, source_count: int, is_independent: bool, 
                             velocity_bonus: bool) -> float:
        """Calculate final confidence score (0-1.0)"""
        confidence = 0.5  # Base
        

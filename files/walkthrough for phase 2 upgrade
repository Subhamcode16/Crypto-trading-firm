        features['liquidity_usd_safe']        = float(a2.get('filters', {}).get('liquidity_check', {}).get('passed', 0))

        # ── AGENT 3: Smart Money / Wallet Signals ─────────────────────────
        a3 = agent_3_data or {}
        features['smart_wallet_count']      = float(len(a3.get('smart_wallets_detected', [])))

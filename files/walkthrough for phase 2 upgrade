                "sources": {
                    "source_count": source_count,
                    "cleared_agents": cleared_sources,
                    "is_independent": is_independent,
                    "independence_factor": independence_factor
                },
                
                "scoring_breakdown": {
                    "base_score": round(base_score, 2),
